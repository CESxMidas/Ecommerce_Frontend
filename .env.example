# ─── Development ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api
API_INTERNAL_URL=http://localhost:888
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXTAUTH_URL=http://localhost:3000/api/next-auth
# Dùng secret cố định trong dev; KHÔNG dùng chung secret với Admin (:3001)
NEXTAUTH_SECRET=change-me-in-development-use-openssl-rand
# Nếu gặp JWT_SESSION_ERROR: xóa cookie localhost cũ (next-auth.session-token) rồi đăng nhập lại

# Google Sign-In — chỉ cần Client ID (Web application)
# Tạo tại: https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000 , https://your-domain.com
# GOOGLE_CLIENT_SECRET (tùy chọn) — chỉ cần nếu dùng NextAuth OAuth redirect
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Production (Vercel / local `npm run build`) ─────────────────
# Vercel: set env in Dashboard. Local build: see `.env.production` in repo.
# NEXT_PUBLIC_API_URL=/api
# API_INTERNAL_URL=https://ecommerce-backend-w4nx.onrender.com
# NEXT_PUBLIC_SITE_URL=https://cerberus-key.vercel.app
# NEXTAUTH_URL=https://cerberus-key.vercel.app/api/next-auth
# NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
#
# Render CORS_ORIGIN (storefront first — VNPay redirect):
#   https://cerberus-key.vercel.app,https://ecommerce-key-admin.vercel.app
